# Variables de entorno para Upstash Redis
# Copia este archivo a .env.local y reemplaza los valores

UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Para obtener estos valores:
# 1. Ve a https://upstash.com
# 2. Crea una cuenta y un proyecto
# 3. Crea una base de datos Redis
# 4. Copia la URL y el REST Token
# 5. Pega los valores aquí
